<!DOCTYPE html>
<html>
<head>
    <title>Search Box Form</title>
    <style>
        body{
            font-family: Arial;
            background:#f2f2f2;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .box{
            background:white;
            padding:30px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
            text-align:center;
            width:300px;
        }

        input{
            width:100%;
            padding:10px;
            margin:10px 0;
        }

        button{
            width:100%;
            padding:10px;
            background:green;
            color:white;
            border:none;
            cursor:pointer;
        }
    </style>
</head>
<body>

<div class="box">
    <h2>Search Box</h2>

    <form action="https://formspree.io/f/xojaevjr" method="POST">

        <input type="text" name="search" placeholder="Type something..." required>

        <button type="submit">Submit</button>

    </form>
</div>

</body>
</html>
